{
  "expo": {
    "name": "UdharPay",
    "slug": "udharpay",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F1219"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.udharpay.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F1219"
      },
      "package": "com.udharpay.app",
      "versionCode": 1
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      [
        "react-native-reanimated",
        {}
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "udharpay"
      }
    }
  }
}
